#!/bin/bash
# jt-quick-task - Desktop quick task capture
#
# Usage:
#   jt-quick-task              # Interactive: pick project, type title
#   jt-quick-task --help       # Show help
#
# Keybinding: Super+Shift+T
# Platform:   Linux (Walker dmenu) / macOS (osascript)

set -euo pipefail

VERSION="0.1.0"
PROJECTS_FILE="$HOME/.config/jat/projects.json"
LAST_PROJECT_FILE="$HOME/.config/jat/quick-task-last-project"
INGEST_DB="$HOME/.local/share/jat/ingest.db"
SOURCE_ID="quick-task-desktop"
IS_MAC=false
[[ "$(uname)" == "Darwin" ]] && IS_MAC=true

show_help() {
    cat <<'EOF'
jt-quick-task - Desktop quick task capture

USAGE:
  jt-quick-task              Pick project via Walker/osascript, type title, create task
  jt-quick-task --help       Show this help
  jt-quick-task --version    Show version

FLOW:
  1. Select project from picker (favorites first, last-used marked)
  2. Type task title
  3. Task created via jt create

KEYBINDING:
  Super+Shift+T

PLATFORM:
  Linux: Walker dmenu + notify-send
  macOS: osascript dialogs + osascript notifications

STATE:
  Last-used project saved to ~/.config/jat/quick-task-last-project
EOF
}

case "${1:-}" in
    -h|--help)
        show_help
        exit 0
        ;;
    --version)
        echo "jt-quick-task $VERSION"
        exit 0
        ;;
esac

# --- Platform UI functions ---

notify_error() {
    local msg="$1"
    if $IS_MAC; then
        osascript -e "display notification \"$msg\" with title \"Quick Task\" sound name \"Basso\""
    else
        notify-send -u critical "Quick Task" "$msg"
    fi
}

notify_success() {
    local msg="$1"
    if $IS_MAC; then
        osascript -e "display notification \"$msg\" with title \"Quick Task\" sound name \"Glass\""
    else
        notify-send -t 3000 "Quick Task" "$msg"
    fi
}

# Show a list picker. Args: prompt, newline-separated items. Returns selected item.
pick_from_list() {
    local prompt="$1"
    local items="$2"
    if $IS_MAC; then
        # Build AppleScript list from items
        local as_list=""
        while IFS= read -r item; do
            [[ -z "$item" ]] && continue
            as_list+="\"$(echo "$item" | sed 's/"/\\"/g')\", "
        done <<< "$items"
        as_list="${as_list%, }"
        osascript -e "choose from list {${as_list}} with prompt \"${prompt}\" with title \"Quick Task\"" 2>/dev/null | grep -v "^false$" || true
    else
        echo "$items" | walker --dmenu -p "$prompt" 2>/dev/null || true
    fi
}

# Show a text input. Args: prompt. Returns typed text.
input_text() {
    local prompt="$1"
    if $IS_MAC; then
        osascript -e "display dialog \"${prompt}\" default answer \"\" with title \"Quick Task\" buttons {\"Cancel\", \"Create\"} default button \"Create\"" -e "text returned of result" 2>/dev/null || true
    else
        walker --dmenu -I -p "$prompt" 2>/dev/null || true
    fi
}

# --- Dependency checks ---

if ! command -v jt &>/dev/null; then
    notify_error "jt not found"
    exit 1
fi
if [[ ! -f "$PROJECTS_FILE" ]]; then
    notify_error "projects.json not found"
    exit 1
fi
if ! $IS_MAC && ! command -v walker &>/dev/null; then
    notify_error "walker not found"
    exit 1
fi

# --- Build project list ---

LAST_PROJECT=""
if [[ -f "$LAST_PROJECT_FILE" ]]; then
    LAST_PROJECT=$(<"$LAST_PROJECT_FILE")
fi

# Build ordered list: last-used (↻) → favorites (★) → rest (alphabetical)
PROJECT_LIST=$(jq -r --arg last "$LAST_PROJECT" '
    .projects | to_entries
    | map(select(
        (.value.hidden // false) == false
    ))
    | map({
        key: .key,
        name: (.value.name // .key),
        path: (.value.path | gsub("^~"; env.HOME)),
        favorite: (.value.favorite // false),
        is_last: (.key == $last)
    })
    | sort_by(.name | ascii_downcase)
    | group_by(
        if .is_last then "0"
        elif .favorite then "1"
        else "2"
        end
    )
    | map(sort_by(.name | ascii_downcase))
    | flatten
    | map(
        (if .is_last then "↻ "
         elif .favorite then "★ "
         else "  " end) + .name + "\t" + .key
    )
    | join("\n")
' "$PROJECTS_FILE")

# Filter to only projects whose path actually exists
FILTERED_LIST=""
while IFS=$'\t' read -r display key; do
    [[ -z "$key" ]] && continue
    path=$(jq -r --arg k "$key" '.projects[$k].path | gsub("^~"; env.HOME)' "$PROJECTS_FILE")
    if [[ -d "$path" ]]; then
        if [[ -n "$FILTERED_LIST" ]]; then
            FILTERED_LIST+=$'\n'
        fi
        FILTERED_LIST+="${display}"$'\t'"${key}"
    fi
done <<< "$PROJECT_LIST"

if [[ -z "$FILTERED_LIST" ]]; then
    notify_error "No projects found"
    exit 1
fi

# --- Project selection ---

DISPLAY_LIST=$(echo "$FILTERED_LIST" | cut -f1)
SELECTED_DISPLAY=$(pick_from_list "Project" "$DISPLAY_LIST")

if [[ -z "$SELECTED_DISPLAY" ]]; then
    exit 0
fi

# Find the matching project key
SELECTED_KEY=$(echo "$FILTERED_LIST" | grep -F "$SELECTED_DISPLAY"$'\t' | head -1 | cut -f2)

if [[ -z "$SELECTED_KEY" ]]; then
    notify_error "Could not match project selection"
    exit 1
fi

PROJECT_PATH=$(jq -r --arg k "$SELECTED_KEY" '.projects[$k].path | gsub("^~"; env.HOME)' "$PROJECTS_FILE")
PROJECT_NAME=$(jq -r --arg k "$SELECTED_KEY" '.projects[$k].name // $k' "$PROJECTS_FILE")

# --- Task title input ---

TASK_TITLE=$(input_text "Task ($PROJECT_NAME)")

if [[ -z "$TASK_TITLE" ]]; then
    exit 0
fi

# --- Create task ---

RESULT=$(cd "$PROJECT_PATH" && jt create "$TASK_TITLE" 2>&1) || {
    notify_error "Failed to create task:\n$RESULT"
    exit 1
}

# Extract task ID from output (format: "Created <id>: <title>")
if $IS_MAC; then
    TASK_ID=$(echo "$RESULT" | sed -n 's/^Created \([^ :]*\).*/\1/p')
else
    TASK_ID=$(echo "$RESULT" | grep -oP '^Created \K\S+' | sed 's/:$//')
fi

# Record in ingest.db so the IDE shows the quick-task icon
if [[ -n "$TASK_ID" ]] && [[ -f "$INGEST_DB" ]]; then
    ITEM_ID="qt-$(date +%s)-$$"
    sqlite3 "$INGEST_DB" "INSERT OR IGNORE INTO ingested_items (source_id, item_id, task_id, title, origin_adapter_type) VALUES ('$SOURCE_ID', '$ITEM_ID', '$TASK_ID', '$(echo "$TASK_TITLE" | sed "s/'/''/g")', 'quick-task');"
fi

# Save last-used project
echo "$SELECTED_KEY" > "$LAST_PROJECT_FILE"

# Notify success
notify_success "Created ${TASK_ID:-task} in $PROJECT_NAME
$TASK_TITLE"

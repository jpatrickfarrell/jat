{
	"name": "jat-ide",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"postinstall": "cd .. && npm install --ignore-scripts",
		"dev": "svelte-kit sync && NODE_OPTIONS='--max-old-space-size=8192 --max-http-header-size=65536' vite dev --host 127.0.0.1",
		"dev:https": "svelte-kit sync && NODE_OPTIONS='--max-old-space-size=8192' vite dev --host 127.0.0.1 --https",
		"build": "vite build",
		"preview": "vite preview",
		"start": "NODE_OPTIONS='--max-old-space-size=8192' node build/index.js",
		"start:http2": "NODE_OPTIONS='--max-old-space-size=8192' node server-http2.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"certs:generate": "mkdir -p certs && cd certs && openssl req -x509 -newkey rsa:2048 -keyout localhost-key.pem -out localhost.pem -days 365 -nodes -subj '/CN=localhost' -addext 'subjectAltName=DNS:localhost,IP:127.0.0.1'",
		"build:feedback": "cd ../feedback && npm run build && npm publish"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.70.1",
		"@humanspeak/svelte-virtual-list": "^0.3.6",
		"@monaco-editor/loader": "^1.7.0",
		"better-sqlite3": "^11.8.1",
		"d3": "^7.9.0",
		"imapflow": "^1.2.8",
		"js-yaml": "^4.1.1",
		"marked": "^17.0.1",
		"monaco-editor": "^0.55.1",
		"pino": "^10.1.0",
		"pino-pretty": "^13.1.3",
		"simple-git": "^3.30.0",
		"svelte-dnd-action": "^0.9.67",
		"theme-change": "^2.5.0",
		"ws": "^8.18.3"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.2.9",
		"@sveltejs/kit": "^2.47.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/postcss": "^4.1.17",
		"@types/better-sqlite3": "^7.6.12",
		"@types/d3": "^7.4.3",
		"@types/js-yaml": "^4.0.9",
		"@types/pino": "^7.0.4",
		"@types/ws": "^8.18.1",
		"@vitest/ui": "^4.0.12",
		"autoprefixer": "^10.4.22",
		"daisyui": "^5.5.5",
		"jat-feedback": "^1.7.0",
		"jsdom": "^27.4.0",
		"postcss": "^8.5.6",
		"svelte": "^5.41.0",
		"svelte-check": "^4.3.3",
		"tailwindcss": "^4.1.17",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.1.10",
		"vite-plugin-static-copy": "^3.2.0",
		"vitest": "^4.0.12"
	}
}

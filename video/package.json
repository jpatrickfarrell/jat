{
  "name": "jat-teaser-video",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render JATTeaser out/teaser.mp4",
    "build:webm": "remotion render JATTeaser out/teaser.webm --codec vp8",
    "still": "remotion still JATTeaser --frame 1200 --output out/poster.jpg --image-format jpeg --jpeg-quality 90"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/player": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.5.0"
  }
}

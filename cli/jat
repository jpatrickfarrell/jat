#------------------------------------------------------------------------------
# Scheduler
#------------------------------------------------------------------------------

scheduler_cmd() {
    local subcmd="${1:-status}"

    local scheduler_dir="$JAT_SOURCE_DIR/tools/scheduler"
    if [[ ! -d "$scheduler_dir" ]]; then
        echo -e "${RED}Error: Scheduler not found at $scheduler_dir${NC}"
        exit 1
    fi

    case "$subcmd" in
        start)
            if tmux has-session -t server-scheduler 2>/dev/null; then
                echo -e "${YELLOW}Scheduler is already running${NC}"
                # Show status
                scheduler_cmd status
                return
            fi
            echo -e "${DIM}Starting scheduler daemon...${NC}"
            tmux new-session -d -s "server-scheduler" -x 80 -y 40 -c "$scheduler_dir"
            sleep 0.3
            tmux send-keys -t "server-scheduler" "bash run.sh" Enter
            echo -e "${GREEN}✓ Scheduler daemon started (tmux session: server-scheduler)${NC}"
            ;;
        stop)
            if ! tmux has-session -t server-scheduler 2>/dev/null; then
                echo -e "${YELLOW}Scheduler is not running${NC}"
                return
            fi
            tmux kill-session -t server-scheduler
            echo -e "${GREEN}✓ Scheduler daemon stopped${NC}"
            ;;
        status)
            if tmux has-session -t server-scheduler 2>/dev/null; then
                echo -e "${GREEN}●${NC} Scheduler is ${GREEN}running${NC} (tmux session: server-scheduler)"
                # Try to get status from HTTP API
                local status
                status=$(curl -s --connect-timeout 2 http://127.0.0.1:3334/status 2>/dev/null)
                if [[ -n "$status" ]]; then
                    local poll_count uptime_secs
                    poll_count=$(echo "$status" | jq -r '.pollCount // 0')
                    uptime_secs=$(echo "$status" | jq -r '.uptime // 0' | cut -d. -f1)
                    local projects
                    projects=$(echo "$status" | jq -r '.projectCount // 0')
                    echo -e "  Polls: ${BOLD}$poll_count${NC}  Projects: ${BOLD}$projects${NC}  Uptime: ${BOLD}${uptime_secs}s${NC}"
                fi
                # Check auto-start config
                if jq -r '.defaults.scheduler_autostart // false' "$CONFIG_FILE" 2>/dev/null | grep -q true; then
                    echo -e "  Auto-start: ${GREEN}enabled${NC}"
                else
                    echo -e "  Auto-start: ${DIM}disabled${NC}"
                fi
            else
                echo -e "${RED}●${NC} Scheduler is ${RED}stopped${NC}"
                if jq -r '.defaults.scheduler_autostart // false' "$CONFIG_FILE" 2>/dev/null | grep -q true; then
                    echo -e "  Auto-start: ${GREEN}enabled${NC} (will start on next IDE launch)"
                else
                    echo -e "  Auto-start: ${DIM}disabled${NC}"
                fi
                echo -e "  Run ${BOLD}jat scheduler start${NC} to start manually"
            fi
            ;;
        restart)
            scheduler_cmd stop
            sleep 0.5
            scheduler_cmd start
            ;;
        logs)
            if ! tmux has-session -t server-scheduler 2>/dev/null; then
                echo -e "${YELLOW}Scheduler is not running${NC}"
                return
            fi
            echo -e "${DIM}Attaching to scheduler logs (Ctrl+B D to detach)...${NC}"
            tmux attach-session -t server-scheduler
            ;;
        *)
            echo "Usage: jat scheduler <start|stop|status|restart|logs>"
            echo ""
            echo "Commands:"
            echo "  start     Start the scheduler daemon"
            echo "  stop      Stop the scheduler daemon"
            echo "  status    Show scheduler status (default)"
            echo "  restart   Restart the scheduler daemon"
            echo "  logs      Attach to scheduler tmux session"
            echo ""
            echo "Config: Set defaults.scheduler_autostart=true in projects.json"
            echo "        to auto-start with IDE launch"
            ;;
    esac
}


#!/bin/bash
#
# jat-step - Execute a completion step with automatic signal emission
#
# Usage:
#   jat-step <step> --task <id> --title <title> --agent <name> [options]
#
# Steps:
#   verifying    - Emit signal only (agent does verification)
#   committing   - Emit signal + git add/commit
#   closing      - Emit signal + jt close
#   callback     - Emit signal + fire integration callback (if configured)
#   sync-status  - Fire integration status_changed callback (no completing signal)
#   releasing    - Emit signal + capture session log
#
# Options:
#   --task <id>       Task ID (required)
#   --title <title>   Task title (required)
#   --agent <name>    Agent name (required)
#   --type <type>     Task type for commit message (default: task)
#   --status <status> Task status for sync-status step (default: in_progress)
#   --help            Show this help
#
# Example:
#   jat-step verifying --task jat-abc --title "Add auth" --agent FreeOcean
#   jat-step committing --task jat-abc --title "Add auth" --agent FreeOcean --type feature
#   jat-step closing --task jat-abc --title "Add auth" --agent FreeOcean
#   jat-step sync-status --task jat-abc --title "Add auth" --agent FreeOcean --status in_progress

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
DIM='\033[2m'
NC='\033[0m'

log() { echo -e "$@" >&2; }
log_dim() { echo -e "${DIM}$@${NC}" >&2; }
log_error() { echo -e "${RED}Error: $@${NC}" >&2; }
log_success() { echo -e "${GREEN}$@${NC}" >&2; }

show_usage() {
    cat >&2 <<'EOF'
jat-step - Execute a completion step with automatic signal emission

Usage:
  jat-step <step> --task <id> --title <title> --agent <name> [options]

Steps:
  verifying    - Emit signal only (agent does verification)
  committing   - Emit signal + git add/commit
  closing      - Emit signal + jt close
  callback     - Emit signal + fire integration callback (if configured)
  sync-status  - Fire integration status_changed callback (no completing signal)
  releasing    - Emit signal + capture session log
  complete     - Generate completion bundle via LLM and emit complete signal

Options:
  --task <id>       Task ID (required)
  --title <title>   Task title (required)
  --agent <name>    Agent name (required)
  --type <type>     Task type for commit message (default: task)
  --help            Show this help

Example:
  jat-step verifying --task jat-abc --title "Add auth" --agent FreeOcean
  jat-step committing --task jat-abc --title "Add auth" --agent FreeOcean --type feature
  jat-step closing --task jat-abc --title "Add auth" --agent FreeOcean
EOF
    exit 0
}

# Step definitions: name -> [progress, stepsCompleted, stepsRemaining, description]
get_step_config() {
    local step="$1"
    case "$step" in
        verifying)
            echo '0|[]|["verifying","committing","closing","callback","releasing"]|Running tests and verification'
            ;;
        committing)
            echo '25|["verifying"]|["committing","closing","callback","releasing"]|Committing changes'
            ;;
        closing)
            echo '50|["verifying","committing"]|["closing","callback","releasing"]|Closing task in JAT'
            ;;
        callback)
            echo '55|["verifying","committing","closing"]|["callback","releasing"]|Firing integration callback'
            ;;
        releasing)
            echo '75|["verifying","committing","closing","callback"]|["releasing"]|Capturing session log'
            ;;
        complete)
            # complete step doesn't emit completing signal - it emits the complete signal
            echo '100|["verifying","committing","closing","callback","releasing"]|[]|Generating completion bundle'
            ;;
        *)
            log_error "Unknown step: $step"
            log "Valid steps: verifying, committing, closing, callback, releasing (session log), complete"
            exit 1
            ;;
    esac
}

emit_completing_signal() {
    local step="$1"
    local task_id="$2"
    local task_title="$3"
    local config
    config=$(get_step_config "$step")

    local progress completed remaining description
    IFS='|' read -r progress completed remaining description <<< "$config"

    local timestamp
    timestamp=$(date -Iseconds)

    jat-signal completing "$(jq -n -c \
        --arg taskId "$task_id" \
        --arg taskTitle "$task_title" \
        --arg currentStep "$step" \
        --argjson stepsCompleted "$completed" \
        --argjson stepsRemaining "$remaining" \
        --argjson progress "$progress" \
        --arg stepDescription "$description" \
        --arg stepStartedAt "$timestamp" \
        '{
            taskId: $taskId,
            taskTitle: $taskTitle,
            currentStep: $currentStep,
            stepsCompleted: $stepsCompleted,
            stepsRemaining: $stepsRemaining,
            progress: $progress,
            stepDescription: $stepDescription,
            stepStartedAt: $stepStartedAt
        }')"
}

# Parse arguments
STEP=""
TASK_ID=""
TASK_TITLE=""
AGENT_NAME=""
TASK_TYPE="task"
TASK_STATUS="in_progress"

# First argument is the step
if [[ $# -gt 0 && ! "$1" =~ ^-- ]]; then
    STEP="$1"
    shift
fi

while [[ $# -gt 0 ]]; do
    case $1 in
        --task)
            TASK_ID="$2"
            shift 2
            ;;
        --title)
            TASK_TITLE="$2"
            shift 2
            ;;
        --agent)
            AGENT_NAME="$2"
            shift 2
            ;;
        --type)
            TASK_TYPE="$2"
            shift 2
            ;;
        --status)
            TASK_STATUS="$2"
            shift 2
            ;;
        --help|-h)
            show_usage
            ;;
        *)
            if [[ -z "$STEP" ]]; then
                STEP="$1"
                shift
            else
                log_error "Unknown option: $1"
                show_usage
            fi
            ;;
    esac
done

# Validate required arguments
if [[ -z "$STEP" ]]; then
    log_error "Step is required"
    show_usage
fi

if [[ -z "$TASK_ID" ]]; then
    log_error "Task ID is required (--task <id>)"
    exit 1
fi

if [[ -z "$TASK_TITLE" ]]; then
    log_error "Task title is required (--title <title>)"
    exit 1
fi

if [[ -z "$AGENT_NAME" ]]; then
    log_error "Agent name is required (--agent <name>)"
    exit 1
fi

# Execute the step
case "$STEP" in
    verifying)
        # Just emit signal - agent does verification
        emit_completing_signal "$STEP" "$TASK_ID" "$TASK_TITLE"
        log_success "Ready for verification"
        ;;

    committing)
        emit_completing_signal "$STEP" "$TASK_ID" "$TASK_TITLE"

        # Check if there are changes to commit
        if [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
            log_dim "Adding and committing changes..."
            git add .
            git commit -m "$(cat <<EOF
${TASK_TYPE}(${TASK_ID}): ${TASK_TITLE}

🤖 Generated with [Claude Code](https://claude.com/claude-code)

Co-Authored-By: Claude <noreply@anthropic.com>
EOF
)"
            log_success "Changes committed"
        else
            log_dim "No changes to commit"
        fi
        ;;

    closing)
        emit_completing_signal "$STEP" "$TASK_ID" "$TASK_TITLE"

        log_dim "Closing task..."
        jt close "$TASK_ID" --reason "Completed by $AGENT_NAME"
        log_success "Task closed: $TASK_ID"
        ;;

    callback)
        emit_completing_signal "$STEP" "$TASK_ID" "$TASK_TITLE"

        # Fire integration callback if this task was ingested from an external source
        log_dim "Checking for integration callback..."
        IDE_URL="http://127.0.0.1:3333"

        # Query IDE for integration info
        INTEGRATION_JSON=$(curl -sf "${IDE_URL}/api/tasks/integrations?taskIds=${TASK_ID}" 2>/dev/null || echo '{}')
        SOURCE_ID=$(echo "$INTEGRATION_JSON" | jq -r ".integrations.\"${TASK_ID}\".sourceId // empty" 2>/dev/null)
        REFERENCE_ID=$(echo "$INTEGRATION_JSON" | jq -r ".integrations.\"${TASK_ID}\".referenceId // empty" 2>/dev/null)
        HAS_CALLBACK=$(echo "$INTEGRATION_JSON" | jq -r ".integrations.\"${TASK_ID}\".callback.url // empty" 2>/dev/null)

        if [[ -z "$SOURCE_ID" || -z "$HAS_CALLBACK" ]]; then
            log_dim "No integration callback configured — skipping"
        else
            # Read the review summary from timeline JSONL (not signal file,
            # which gets overwritten by emit_completing_signal above).
            # The timeline preserves all signals in order — find the last review entry.
            TMUX_SESSION=$(tmux display-message -p '#S' 2>/dev/null || true)
            TIMELINE_FILE="/tmp/jat-timeline-${TMUX_SESSION}.jsonl"
            SIGNAL_FILE="/tmp/jat-signal-tmux-${TMUX_SESSION}.json"
            SUMMARY_NOTES=""

            # Try timeline first (has review signal preserved)
            if [[ -f "$TIMELINE_FILE" ]]; then
                REVIEW_LINE=$(grep '"state":"review"' "$TIMELINE_FILE" | tail -1)
                if [[ -n "$REVIEW_LINE" ]]; then
                    SUMMARY_ARRAY=$(echo "$REVIEW_LINE" | jq -r '.data.summary // empty' 2>/dev/null)
                    if [[ -n "$SUMMARY_ARRAY" && "$SUMMARY_ARRAY" != "null" ]]; then
                        SUMMARY_NOTES=$(echo "$REVIEW_LINE" | jq -r '"## What was done\n" + ([.data.summary[] | "- " + .] | join("\n"))' 2>/dev/null || echo "")
                    fi
                fi
            fi

            # Fallback 1: try signal file (works if review wasn't overwritten)
            if [[ -z "$SUMMARY_NOTES" && -f "$SIGNAL_FILE" ]]; then
                SUMMARY_ARRAY=$(jq -r '.data.summary // empty' "$SIGNAL_FILE" 2>/dev/null)
                if [[ -n "$SUMMARY_ARRAY" && "$SUMMARY_ARRAY" != "null" ]]; then
                    SUMMARY_NOTES=$(jq -r '"## What was done\n" + ([.data.summary[] | "- " + .] | join("\n"))' "$SIGNAL_FILE" 2>/dev/null || echo "")
                fi
            fi

            # Fallback 2: extract from git commit messages for this task
            # (committing step already ran, so commits exist)
            if [[ -z "$SUMMARY_NOTES" ]]; then
                COMMITS=$(git log --oneline --grep="${TASK_ID}" -10 2>/dev/null | sed 's/^[a-f0-9]* /- /')
                if [[ -n "$COMMITS" ]]; then
                    SUMMARY_NOTES="## What was done"$'\n'"${COMMITS}"
                    log_dim "No review signal found — using commit messages for dev_notes"
                fi
            fi

            # Fire callback
            log_dim "Firing callback to ${SOURCE_ID}..."
            CALLBACK_BODY=$(jq -n -c \
                --arg taskId "$TASK_ID" \
                --arg event "task_closed" \
                --arg referenceId "$REFERENCE_ID" \
                --arg taskStatus "closed" \
                --arg notes "$SUMMARY_NOTES" \
                '{taskId: $taskId, event: $event, referenceId: $referenceId, taskStatus: $taskStatus, notes: $notes}')

            CALLBACK_RESULT=$(curl -sf -X POST "${IDE_URL}/api/integrations/${SOURCE_ID}/callback" \
                -H "Content-Type: application/json" \
                -d "$CALLBACK_BODY" 2>/dev/null || echo '{"success":false}')

            CALLBACK_OK=$(echo "$CALLBACK_RESULT" | jq -r '.success // false' 2>/dev/null)
            if [[ "$CALLBACK_OK" == "true" ]]; then
                CALLBACK_MS=$(echo "$CALLBACK_RESULT" | jq -r '.duration_ms // "?"' 2>/dev/null)
                log_success "Integration callback fired (${CALLBACK_MS}ms)"
            else
                CALLBACK_ERR=$(echo "$CALLBACK_RESULT" | jq -r '.error // "unknown error"' 2>/dev/null)
                log_dim "Integration callback failed: ${CALLBACK_ERR} (non-blocking)"
            fi
        fi
        ;;

    sync-status)
        # Fire integration status_changed callback — no completing signal
        # Used by /jat:start to sync in_progress status to external systems
        log_dim "Syncing status '${TASK_STATUS}' to integration..."
        IDE_URL="http://127.0.0.1:3333"

        # Query IDE for integration info
        INTEGRATION_JSON=$(curl -sf "${IDE_URL}/api/tasks/integrations?taskIds=${TASK_ID}" 2>/dev/null || echo '{}')
        SOURCE_ID=$(echo "$INTEGRATION_JSON" | jq -r ".integrations.\"${TASK_ID}\".sourceId // empty" 2>/dev/null)
        REFERENCE_ID=$(echo "$INTEGRATION_JSON" | jq -r ".integrations.\"${TASK_ID}\".referenceId // empty" 2>/dev/null)
        HAS_CALLBACK=$(echo "$INTEGRATION_JSON" | jq -r ".integrations.\"${TASK_ID}\".callback.url // empty" 2>/dev/null)

        if [[ -z "$SOURCE_ID" || -z "$HAS_CALLBACK" ]]; then
            log_dim "No integration callback configured — skipping"
        else
            # Fire status_changed callback
            log_dim "Firing status_changed to ${SOURCE_ID}..."
            CALLBACK_BODY=$(jq -n -c \
                --arg taskId "$TASK_ID" \
                --arg event "status_changed" \
                --arg referenceId "$REFERENCE_ID" \
                --arg taskStatus "$TASK_STATUS" \
                '{taskId: $taskId, event: $event, referenceId: $referenceId, taskStatus: $taskStatus}')

            CALLBACK_RESULT=$(curl -sf -X POST "${IDE_URL}/api/integrations/${SOURCE_ID}/callback" \
                -H "Content-Type: application/json" \
                -d "$CALLBACK_BODY" 2>/dev/null || echo '{"success":false}')

            CALLBACK_OK=$(echo "$CALLBACK_RESULT" | jq -r '.success // false' 2>/dev/null)
            if [[ "$CALLBACK_OK" == "true" ]]; then
                CALLBACK_MS=$(echo "$CALLBACK_RESULT" | jq -r '.duration_ms // "?"' 2>/dev/null)
                log_success "Status synced to integration (${CALLBACK_MS}ms)"
            else
                CALLBACK_ERR=$(echo "$CALLBACK_RESULT" | jq -r '.error // "unknown error"' 2>/dev/null)
                log_dim "Status sync failed: ${CALLBACK_ERR} (non-blocking)"
            fi
        fi
        ;;

    releasing)
        emit_completing_signal "$STEP" "$TASK_ID" "$TASK_TITLE"

        # Capture session log while tmux session is still alive
        # This is the reliable capture point — SessionCard detection is racy
        TMUX_SESSION=$(tmux display-message -p '#S' 2>/dev/null || true)
        if [[ -n "$TMUX_SESSION" ]]; then
            log_dim "Capturing session log..."
            capture-session-log.sh "$TMUX_SESSION" "completed" 2>/dev/null && \
                log_success "Session log captured" || \
                log_dim "Session log capture skipped"
        fi

        log_dim "File declarations cleared by task close"
        ;;

    complete)
        # No completing signal - this step emits the final complete signal
        log_dim "Generating completion bundle via LLM..."
        if jat-complete-bundle --task "$TASK_ID" --agent "$AGENT_NAME" --emit; then
            log_success "Completion bundle emitted"
        else
            # Bundle generation failed — emit a minimal complete signal so the IDE
            # transitions past "releasing" instead of getting stuck
            log_warn "Bundle generation failed (exit $?) — emitting fallback complete signal"
            jat-signal complete "$(jq -n -c \
                --arg taskId "$TASK_ID" \
                --arg agentName "$AGENT_NAME" \
                '{
                    taskId: $taskId,
                    agentName: $agentName,
                    completionMode: "review_required",
                    summary: ["Task completed (completion bundle generation failed)"],
                    quality: {tests: "skipped", build: "clean"},
                    suggestedTasks: [],
                    suggestedLabels: [],
                    riskLevel: "low"
                }')"
            log_success "Fallback complete signal emitted"
        fi

        # If the bundle contains a devResponse, fire an integration callback
        # to update dev_notes with the user-friendly message (overrides the
        # technical summary sent during the earlier callback step).
        TMUX_SESSION=$(tmux display-message -p '#S' 2>/dev/null || true)
        TIMELINE_FILE="/tmp/jat-timeline-${TMUX_SESSION}.jsonl"
        if [[ -n "$TMUX_SESSION" && -f "$TIMELINE_FILE" ]]; then
            # complete is a data signal: stored as "type":"complete" not "state":"complete"
            COMPLETE_LINE=$(grep '"type":"complete"' "$TIMELINE_FILE" | tail -1 || true)
            DEV_RESPONSE=$(echo "$COMPLETE_LINE" | jq -r '.data.devResponse // empty' 2>/dev/null)
            if [[ -n "$DEV_RESPONSE" ]]; then
                IDE_URL="http://127.0.0.1:3333"
                INTEGRATION_JSON=$(curl -sf "${IDE_URL}/api/tasks/integrations?taskIds=${TASK_ID}" 2>/dev/null || echo '{}')
                SOURCE_ID=$(echo "$INTEGRATION_JSON" | jq -r ".integrations.\"${TASK_ID}\".sourceId // empty" 2>/dev/null)
                REFERENCE_ID=$(echo "$INTEGRATION_JSON" | jq -r ".integrations.\"${TASK_ID}\".referenceId // empty" 2>/dev/null)
                HAS_CALLBACK=$(echo "$INTEGRATION_JSON" | jq -r ".integrations.\"${TASK_ID}\".callback.url // empty" 2>/dev/null)

                if [[ -n "$SOURCE_ID" && -n "$HAS_CALLBACK" ]]; then
                    log_dim "Updating dev_notes with user-friendly response..."
                    CALLBACK_BODY=$(jq -n -c \
                        --arg taskId "$TASK_ID" \
                        --arg event "task_closed" \
                        --arg referenceId "$REFERENCE_ID" \
                        --arg taskStatus "closed" \
                        --arg notes "$DEV_RESPONSE" \
                        '{taskId: $taskId, event: $event, referenceId: $referenceId, taskStatus: $taskStatus, notes: $notes}')

                    CALLBACK_RESULT=$(curl -sf -X POST "${IDE_URL}/api/integrations/${SOURCE_ID}/callback" \
                        -H "Content-Type: application/json" \
                        -d "$CALLBACK_BODY" 2>/dev/null || echo '{"success":false}')

                    CALLBACK_OK=$(echo "$CALLBACK_RESULT" | jq -r '.success // false' 2>/dev/null)
                    if [[ "$CALLBACK_OK" == "true" ]]; then
                        log_success "Dev response updated for reporter"
                    else
                        log_dim "Dev response callback failed (non-blocking)"
                    fi
                fi
            fi
        fi
        ;;

    *)
        log_error "Unknown step: $STEP"
        exit 1
        ;;
esac

        local b7=$'\033[38;5;80m'                           # T stem: teal
        local d=$'\033[2m'                                  # dim for tagline
        echo "${b1}${B}  ╔───────────────${b3}───────────────${b5}─────────────╗${R}"
        echo "${b1}${B}  │${R}                                           ${b5}${B}│${R}"
        echo "${b1}${B}  │${R}${b1}${B}           __${R}       ${b3}${B}___${R}   ${b5}${B}.___________.${R}    ${b5}${B}│${R}"
        echo "${b1}${B}  │${R}${b1}${B}          |  |${R}     ${b3}${B}/   \\ ${R} ${b5}${B}|           |${R}    ${b5}${B}│${R}"
        echo "${b1}${B}  │${R}${b1}${B}          |  |${R}    ${b3}${B}/  ^  \\ ${R}${b5}${B}\`---|  |----\`${R}    ${b5}${B}│${R}"
        echo "${b2}${B}  │${R}${b2}${B}    .--.  |  |${R}   ${b4}${B}/  /_\\  \\ ${R}   ${b6}${B}|  |${R}         ${b6}${B}│${R}"
        echo "${b2}${B}  │${R}${b2}${B}    |  \`--'  |${R}  ${b4}${B}/  _____  \\ ${R}  ${b6}${B}|  |${R}         ${b6}${B}│${R}"
        echo "${b2}${B}  │${R}${b2}${B}     \\______/${R}  ${b4}${B}/__/     \\__\\ ${R} ${b7}${B}|__|${R}         ${b7}${B}│${R}"
        echo "${b2}${B}  │${R}                                           ${b7}${B}│${R}"
        echo "${b2}${B}  │${R}${d}         ◇ Supervise the Swarm ◇${R}           ${b7}${B}│${R}"
        echo "${b3}${B}  │${R}                                           ${b7}${B}│${R}"
        echo "${b3}${B}  ╚───────────────${b5}───────────────${b7}─────────────╝${R}"
        echo ""

        # Check prerequisites (tmux, node, npm) - offer to install if missing
        if ! check_prerequisites; then
            exit 1
        fi

        # Check for updates only on IDE launch (interactive prompt)
        interactive_update_check

        # Ensure all configured projects have .jat/ initialized
        ensure_project_dbs

        # Sweep zombie tasks (in_progress with no live tmux session)
        sweep_zombie_tasks

        # Auto-start scheduler daemon if configured
        if jq -r '.defaults.scheduler_autostart // false' "$CONFIG_FILE" 2>/dev/null | grep -q true; then
            if ! tmux has-session -t server-scheduler 2>/dev/null; then
                local scheduler_dir="$JAT_SOURCE_DIR/tools/scheduler"
                if [[ -d "$scheduler_dir" ]]; then
                    echo -e "${DIM}  → Starting scheduler daemon...${NC}"
                    tmux new-session -d -s "server-scheduler" -x 80 -y 40 -c "$scheduler_dir"
                    sleep 0.3
                    tmux send-keys -t "server-scheduler" "bash run.sh" Enter
                    echo -e "${GREEN}  ✓ Scheduler daemon started${NC}"
                fi
            fi
        fi

        launch_ide "JAT"
        exit 0
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        help|--help|-h)
            show_help
            ;;
        list|ls)
            list_all
            ;;
        init)
            init_projects
            ;;
        config)
            show_config "$@"
            ;;
        edit)
            edit_config
            ;;
        cleanup)
            cleanup_agents "$@"
            ;;
        add)
            add_project "$@"
            ;;
        remove|rm)
            remove_project "$@"
            ;;
        resume|-r)
            resume_session "$@"
            ;;
        find-session|-fs)
            find_session_cmd "$@"
            ;;
        demo)
            demo_cmd "$@"
            ;;
        update)
            update_cmd "$@"
            ;;
        scheduler)
            scheduler_cmd "$@"
            ;;
        # Hidden/advanced commands (kept for backwards compatibility)
        colors)
            apply_all_colors
            ;;
        hooks)
            install_hooks "$@"
            ;;
        *)
            # Check if it's a known project (backwards compatibility)
            local config
            config=$(get_project_config "$cmd")
            if [[ -n "$config" ]]; then
                echo -e "${YELLOW}Note: Direct project launching is deprecated.${NC}"
                echo -e "${YELLOW}Please use the IDE to manage agents.${NC}"
                echo ""
                launch_project "$cmd" "$@"
            else
                echo -e "${RED}Unknown command: $cmd${NC}"
                echo "Run 'jat --help' for usage"
                exit 1
            fi
            ;;
    esac
}

main "$@"

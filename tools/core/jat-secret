#!/bin/bash
#
# jat-secret - Retrieve secrets from JAT credentials store
#
# Usage:
#   jat-secret <key-name>                          # Get secret value by name
#   jat-secret --project <proj> <key>              # Get project secret directly
#   jat-secret --set <key> <value> [--env VAR] [--desc "..."]  # Set a custom key
#   jat-secret --delete <key-name>                 # Delete a custom key
#   jat-secret --list                              # List all custom key names
#   jat-secret --export                            # Output export statements for all keys
#   jat-secret --env <key-name>                    # Get the env var name for a key
#   jat-secret --help                              # Show this help
#
# Examples:
#   jat-secret stripe                              # Outputs: sk_live_xxx...
#   jat-secret steelbridge-supabase-service-role-key  # Resolves from project secrets
#   jat-secret --project steelbridge supabase_service_role_key  # Direct project access
#   jat-secret --set my-api "sk_xxx" --env MY_API_KEY --desc "My API key"
#   jat-secret --set my-api "sk_xxx"               # Auto-derives env var: MY_API
#   jat-secret --delete my-api                     # Remove a key
#   jat-secret --env stripe                        # Outputs: STRIPE_API_KEY
#   eval $(jat-secret --export)                    # Load all keys as env vars
#   MY_VAR=$(jat-secret my-service)                # Use in scripts
#
# Security:
#   - Reads from ~/.config/jat/credentials.json
#   - Values are not logged or displayed in --list
#   - Use in subshells to avoid leaking to process environment
#

set -euo pipefail

CREDENTIALS_FILE="$HOME/.config/jat/credentials.json"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

show_help() {
    cat << 'EOF'
jat-secret - Retrieve and manage secrets in JAT credentials store

USAGE:
    jat-secret <key-name>                          Get secret value by name
    jat-secret --project <proj> <key>              Get project secret directly
    jat-secret --set <key> <value> [OPTIONS]       Set a custom key
    jat-secret --delete <key-name>                 Delete a custom key
    jat-secret --list                              List all custom key names
    jat-secret --export                            Output export statements
    jat-secret --env <key-name>                    Get the env var name for a key
    jat-secret --help                              Show this help

SET OPTIONS:
    --env VAR_NAME    Environment variable name (default: auto-derived from key)
    --desc "text"     Description of what the key is for

EXAMPLES:
    jat-secret stripe                                  # Get a secret
    jat-secret steelbridge-supabase-service-role-key   # From project secrets
    jat-secret --project steelbridge supabase_service_role_key  # Direct access
    jat-secret --set my-api "sk_xxx"                   # Set (env var auto-derived)
    jat-secret --set my-api "sk_xxx" --env MY_KEY      # Set with explicit env var
    jat-secret --set my-api "sk_xxx" --desc "My key"   # Set with description
    jat-secret --delete my-api                         # Delete a key
    jat-secret --env stripe                            # Get env var name
    eval $(jat-secret --export)                        # Load all as env vars

PROVIDER KEYS:
    jat-secret anthropic               # Anthropic API key
    jat-secret google                  # Google/Gemini API key
    jat-secret openai                  # OpenAI API key
    jat-secret slack                   # Slack Bot Token
    jat-secret telegram                # Telegram Bot Token
    jat-secret cloudflare              # Cloudflare API Token
    jat-secret github                  # GitHub Token
    (+ discord, gmail, vercel, fly, convex, linear, sentry,
     turso, upstash, neon, pinecone, resend, twilio, openrouter)

PROJECT SECRET FALLBACK:
    Names like "project-secret-key" are resolved from projectSecrets:
    1. Find longest matching project prefix
    2. Strip prefix + dash, convert dashes to underscores
    3. Look up in projectSecrets.<project>.<key>.value
EOF
}

error() {
    echo -e "${RED}error:${NC} $1" >&2
    exit 1
}

# Check if credentials file exists
check_credentials() {
    if [[ ! -f "$CREDENTIALS_FILE" ]]; then
        error "Credentials file not found: $CREDENTIALS_FILE\nRun the IDE and configure keys in Settings -> API Keys"
    fi
}

# Get a project secret by project name and key name
# e.g., get_project_secret "steelbridge" "supabase_service_role_key"
get_project_secret() {
    local project="$1"
    local key="$2"
    check_credentials

    local value
    value=$(jq -r ".projectSecrets.\"$project\".\"$key\".value // empty" "$CREDENTIALS_FILE" 2>/dev/null)

    if [[ -z "$value" ]]; then
        error "Project secret not found: $project/$key\nConfigure in IDE Settings → Project Secrets"
    fi

    echo "$value"
}

# Try to resolve a name from project secrets by prefix matching.
# For "steelbridge-supabase-service-role-key":
#   1. Get all project names from projectSecrets
#   2. Find longest project name that is a prefix of the name
#   3. Strip "<project>-" prefix, convert remaining dashes to underscores
#   4. Look up projectSecrets.<project>.<key>.value
try_project_secret() {
    local name="$1"

    # Get all project names, sorted longest-first for greedy matching
    local projects
    projects=$(jq -r '.projectSecrets // {} | keys[]' "$CREDENTIALS_FILE" 2>/dev/null | awk '{ print length, $0 }' | sort -rn | awk '{ print $2 }')

    [[ -z "$projects" ]] && return 1

    while IFS= read -r project; do
        [[ -z "$project" ]] && continue
        # Check if name starts with "<project>-"
        if [[ "$name" == "${project}-"* ]]; then
            local remainder="${name#${project}-}"
            # Convert dashes to underscores
            local key="${remainder//-/_}"
            local value
            value=$(jq -r ".projectSecrets.\"$project\".\"$key\".value // empty" "$CREDENTIALS_FILE" 2>/dev/null)
            if [[ -n "$value" ]]; then
                echo "$value"
                return 0
            fi
        fi
    done <<< "$projects"

    return 1
}

# Get a custom API key value
get_custom_key() {
    local name="$1"
    check_credentials

    local value
    value=$(jq -r ".customApiKeys.\"$name\".value // empty" "$CREDENTIALS_FILE" 2>/dev/null)

    if [[ -z "$value" ]]; then
        # Try built-in API keys
        value=$(jq -r ".apiKeys.\"$name\".key // empty" "$CREDENTIALS_FILE" 2>/dev/null)
    fi

    if [[ -z "$value" ]]; then
        # Try project secrets by prefix matching
        value=$(try_project_secret "$name") && { echo "$value"; return; }
    fi

    if [[ -z "$value" ]]; then
        error "Key not found: $name\nUse 'jat-secret --list' to see available keys"
    fi

    echo "$value"
}

# Get env var name for a custom key
get_env_var() {
    local name="$1"
    check_credentials

    # Check custom keys first
    local env_var
    env_var=$(jq -r ".customApiKeys.\"$name\".envVar // empty" "$CREDENTIALS_FILE" 2>/dev/null)

    if [[ -n "$env_var" ]]; then
        echo "$env_var"
        return
    fi

    # Check provider keys
    env_var=$(provider_env_var "$name")
    if [[ -n "$env_var" ]]; then
        echo "$env_var"
        return
    fi

    error "Key not found: $name"
}

# List all custom key names
list_keys() {
    check_credentials

    echo "Provider keys:"
    # Dynamically enumerate all keys in apiKeys
    local provider_keys
    provider_keys=$(jq -r '.apiKeys // {} | to_entries[] | select(.value.key != null and .value.key != "") | .key' "$CREDENTIALS_FILE" 2>/dev/null)
    if [[ -z "$provider_keys" ]]; then
        echo "  (none configured)"
    else
        while IFS= read -r key; do
            echo "  $key"
        done <<< "$provider_keys"
    fi

    echo ""
    echo "Custom keys:"
    local custom_keys
    custom_keys=$(jq -r '.customApiKeys // {} | keys[]' "$CREDENTIALS_FILE" 2>/dev/null)

    if [[ -z "$custom_keys" ]]; then
        echo "  (none configured)"
    else
        while IFS= read -r key; do
            local env_var
            env_var=$(jq -r ".customApiKeys.\"$key\".envVar" "$CREDENTIALS_FILE")
            local desc
            desc=$(jq -r ".customApiKeys.\"$key\".description // \"\"" "$CREDENTIALS_FILE")
            if [[ -n "$desc" ]]; then
                echo "  $key ($env_var) - $desc"
            else
                echo "  $key ($env_var)"
            fi
        done <<< "$custom_keys"
    fi

    echo ""
    echo "Project secrets:"
    local projects
    projects=$(jq -r '.projectSecrets // {} | keys[]' "$CREDENTIALS_FILE" 2>/dev/null)

    if [[ -z "$projects" ]]; then
        echo "  (none configured)"
    else
        while IFS= read -r project; do
            [[ -z "$project" ]] && continue
            local secret_keys
            secret_keys=$(jq -r ".projectSecrets.\"$project\" // {} | keys[]" "$CREDENTIALS_FILE" 2>/dev/null)
            while IFS= read -r skey; do
                [[ -z "$skey" ]] && continue
                # Show as <project>-<key-with-dashes>
                local display_key="${skey//_/-}"
                echo "  ${project}-${display_key} (project: $project)"
            done <<< "$secret_keys"
        done <<< "$projects"
    fi
}

# Map provider id to env var name (used by --env and --export)
# Returns empty if unknown (caller should fall back to custom keys)
provider_env_var() {
    local id="$1"
    case "$id" in
        anthropic)  echo "ANTHROPIC_API_KEY" ;;
        google)     echo "GEMINI_API_KEY" ;;
        openai)     echo "OPENAI_API_KEY" ;;
        openrouter) echo "OPENROUTER_API_KEY" ;;
        slack)      echo "SLACK_BOT_TOKEN" ;;
        telegram)   echo "TELEGRAM_BOT_TOKEN" ;;
        discord)    echo "DISCORD_BOT_TOKEN" ;;
        gmail)      echo "GMAIL_APP_PASSWORD" ;;
        cloudflare) echo "CLOUDFLARE_API_TOKEN" ;;
        vercel)     echo "VERCEL_TOKEN" ;;
        fly)        echo "FLY_API_TOKEN" ;;
        convex)     echo "CONVEX_DEPLOY_KEY" ;;
        github)     echo "GITHUB_TOKEN" ;;
        linear)     echo "LINEAR_API_KEY" ;;
        sentry)     echo "SENTRY_AUTH_TOKEN" ;;
        turso)      echo "TURSO_AUTH_TOKEN" ;;
        upstash)    echo "UPSTASH_REST_TOKEN" ;;
        neon)       echo "NEON_API_KEY" ;;
        pinecone)   echo "PINECONE_API_KEY" ;;
        resend)     echo "RESEND_API_KEY" ;;
        twilio)     echo "TWILIO_AUTH_TOKEN" ;;
        *)          echo "" ;;
    esac
}

# Export all custom keys as shell export statements
export_keys() {
    check_credentials

    # Export all provider keys dynamically
    local provider_entries
    provider_entries=$(jq -r '.apiKeys // {} | to_entries[] | select(.value.key != null and .value.key != "") | "\(.key)\t\(.value.key)"' "$CREDENTIALS_FILE" 2>/dev/null)

    while IFS=$'\t' read -r key value; do
        [[ -z "$key" ]] && continue
        local env_var
        env_var=$(provider_env_var "$key")
        if [[ -z "$env_var" ]]; then
            # Unknown provider - derive from key name
            env_var=$(derive_env_var "$key")
        fi
        local escaped_value="${value//\'/\'\\\'\'}"
        echo "export $env_var='$escaped_value'"
    done <<< "$provider_entries"

    # Export custom keys
    local custom_keys
    custom_keys=$(jq -r '.customApiKeys // {} | keys[]' "$CREDENTIALS_FILE" 2>/dev/null)

    while IFS= read -r key; do
        [[ -z "$key" ]] && continue
        local env_var value
        env_var=$(jq -r ".customApiKeys.\"$key\".envVar" "$CREDENTIALS_FILE")
        value=$(jq -r ".customApiKeys.\"$key\".value" "$CREDENTIALS_FILE")
        # Escape single quotes
        local escaped_value="${value//\'/\'\\\'\'}"
        echo "export $env_var='$escaped_value'"
    done <<< "$custom_keys"

    # Export project secrets
    # Each project secret exports as <PROJECT>_<KEY> (all uppercase)
    local projects
    projects=$(jq -r '.projectSecrets // {} | keys[]' "$CREDENTIALS_FILE" 2>/dev/null)

    while IFS= read -r project; do
        [[ -z "$project" ]] && continue
        local secret_keys
        secret_keys=$(jq -r ".projectSecrets.\"$project\" // {} | keys[]" "$CREDENTIALS_FILE" 2>/dev/null)
        while IFS= read -r skey; do
            [[ -z "$skey" ]] && continue
            local value
            value=$(jq -r ".projectSecrets.\"$project\".\"$skey\".value // empty" "$CREDENTIALS_FILE" 2>/dev/null)
            [[ -z "$value" ]] && continue
            # ENV var: PROJECT_KEY (all uppercase)
            local env_var
            env_var=$(echo "${project}_${skey}" | tr '[:lower:]-' '[:upper:]_')
            local escaped_value="${value//\'/\'\\\'\'}"
            echo "export $env_var='$escaped_value'"
        done <<< "$secret_keys"
    done <<< "$projects"
}

# Derive env var name from key name: "my-api-key" -> "MY_API_KEY"
derive_env_var() {
    local name="$1"
    echo "$name" | tr '[:lower:]-' '[:upper:]_'
}

# Set a custom key
set_key() {
    local name="$1"
    local value="$2"
    shift 2

    local env_var=""
    local description=""

    # Parse optional flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --env)
                env_var="${2:-}"
                [[ -z "$env_var" ]] && error "--env requires a value"
                shift 2
                ;;
            --desc)
                description="${2:-}"
                [[ -z "$description" ]] && error "--desc requires a value"
                shift 2
                ;;
            *)
                error "Unknown option for --set: $1"
                ;;
        esac
    done

    # Auto-derive env var if not specified
    if [[ -z "$env_var" ]]; then
        env_var=$(derive_env_var "$name")
    fi

    # Ensure credentials file and directory exist
    mkdir -p "$(dirname "$CREDENTIALS_FILE")"
    if [[ ! -f "$CREDENTIALS_FILE" ]]; then
        echo '{"apiKeys":{},"customApiKeys":{}}' > "$CREDENTIALS_FILE"
    fi

    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")

    # Build the new entry
    local entry
    entry=$(jq -n \
        --arg val "$value" \
        --arg env "$env_var" \
        --arg desc "$description" \
        --arg ts "$timestamp" \
        '{value: $val, envVar: $env, description: $desc, addedAt: $ts}')

    # Upsert into customApiKeys
    local tmp
    tmp=$(mktemp)
    jq --arg name "$name" --argjson entry "$entry" \
        '.customApiKeys[$name] = $entry' "$CREDENTIALS_FILE" > "$tmp" && mv "$tmp" "$CREDENTIALS_FILE"

    echo -e "${GREEN}Set${NC} $name (${env_var})"
}

# Delete a custom key
delete_key() {
    local name="$1"
    check_credentials

    # Check it exists
    local exists
    exists=$(jq -r ".customApiKeys.\"$name\" // empty" "$CREDENTIALS_FILE" 2>/dev/null)
    if [[ -z "$exists" ]]; then
        error "Key not found: $name"
    fi

    local tmp
    tmp=$(mktemp)
    jq --arg name "$name" 'del(.customApiKeys[$name])' "$CREDENTIALS_FILE" > "$tmp" && mv "$tmp" "$CREDENTIALS_FILE"

    echo -e "${GREEN}Deleted${NC} $name"
}

# Main
case "${1:-}" in
    --help|-h)
        show_help
        ;;
    --list|-l)
        list_keys
        ;;
    --export|-e)
        export_keys
        ;;
    --set|-s)
        if [[ -z "${2:-}" ]] || [[ -z "${3:-}" ]]; then
            error "Usage: jat-secret --set <key> <value> [--env VAR] [--desc \"...\"]"
        fi
        set_key "$2" "$3" "${@:4}"
        ;;
    --delete|--rm)
        if [[ -z "${2:-}" ]]; then
            error "Usage: jat-secret --delete <key-name>"
        fi
        delete_key "$2"
        ;;
    --project|-p)
        if [[ -z "${2:-}" ]] || [[ -z "${3:-}" ]]; then
            error "Usage: jat-secret --project <project-name> <secret-key>"
        fi
        get_project_secret "$2" "$3"
        ;;
    --env)
        if [[ -z "${2:-}" ]]; then
            error "Usage: jat-secret --env <key-name>"
        fi
        get_env_var "$2"
        ;;
    "")
        error "Usage: jat-secret <key-name>\nUse --help for more options"
        ;;
    -*)
        error "Unknown option: $1\nUse --help for usage"
        ;;
    *)
        get_custom_key "$1"
        ;;
esac
